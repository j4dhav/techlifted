# ─────────────────────────────────────────────────────────────────────────────
# EduBridge Frontend — Environment Variables (Vite)
# Copy to `.env`. Only variables prefixed with VITE_ are exposed to the browser.
# ─────────────────────────────────────────────────────────────────────────────

# Backend API base URL.
# LOCAL DEV: leave EMPTY — the Vite dev server proxies /api to the backend
#            (see vite.config.ts).
# PRODUCTION: set to your deployed backend origin, e.g.
#            https://edubridge-api.onrender.com
VITE_API_BASE_URL=

# Used by the dev proxy target (optional; defaults to http://localhost:4000).
VITE_API_PROXY_TARGET=http://localhost:4000

# Public WhatsApp community invite link shown on the site (floating button,
# success screen, contact page). Falls back to a placeholder if unset.
VITE_WHATSAPP_COMMUNITY=https://chat.whatsapp.com/your-invite-code
