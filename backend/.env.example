# ─────────────────────────────────────────────────────────────────────────────
# EduBridge Backend — Environment Variables
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# ─────────────────────────────────────────────────────────────────────────────

# Server
NODE_ENV=development
PORT=4000

# Comma-separated list of allowed frontend origins (CORS).
# Local dev default is the Vite dev server.
CORS_ORIGIN=http://localhost:5173

# Admin token — gates GET /api/applications and POST /api/whatsapp/invite,
# and unlocks the /admin page. Use a long random string.
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_TOKEN=

# Storage
DATABASE_FILE=data/edubridge.sqlite
UPLOAD_DIR=uploads
MAX_UPLOAD_BYTES=5242880

# Phone defaults
DEFAULT_COUNTRY_CODE=+91

# ── Google Sheets (service account) ─────────────────────────────────────────
# 1. Create a Google Cloud project, enable the Google Sheets API.
# 2. Create a service account, download its JSON key.
# 3. Share your target spreadsheet with the service account's client_email
#    (Editor access).
# 4. base64-encode the JSON key and paste it below:
#    macOS/Linux: base64 -i service-account.json | tr -d '\n'
#    Windows PS:  [Convert]::ToBase64String([IO.File]::ReadAllBytes("service-account.json"))
GOOGLE_SERVICE_ACCOUNT_BASE64=
# The spreadsheet ID is the long string in the sheet URL between /d/ and /edit.
GOOGLE_SHEET_ID=
GOOGLE_SHEET_NAME=EduBridge Enrollment Data

# ── Twilio WhatsApp ─────────────────────────────────────────────────────────
# From the Twilio Console. For testing, activate the WhatsApp Sandbox and use
# its sender number. For production, provision a WhatsApp Business sender.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Include the whatsapp: prefix, e.g. whatsapp:+14155238886
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# The invite link to your WhatsApp Community/Group.
WHATSAPP_COMMUNITY_LINK=https://chat.whatsapp.com/your-invite-code
